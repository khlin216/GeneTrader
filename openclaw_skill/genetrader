#!/usr/bin/env python3
"""
GeneTrader OpenClaw Skill

This script provides the command-line interface for OpenClaw to interact
with the GeneTrader adaptive optimization system.

Usage:
    genetrader check [strategy_name]
    genetrader status
    genetrader optimize [strategy_name]
    genetrader approvals
    genetrader approve <request_id>
    genetrader reject <request_id> [reason]
    genetrader rollback <strategy_name> [version_id]
"""

import json
import os
import subprocess
import sys
from urllib.request import Request, urlopen
from urllib.error import URLError


def get_config():
    """Get configuration from environment."""
    return {
        'genetrader_path': os.environ.get('GENETRADER_PATH', os.path.expanduser('~/GeneTrader')),
        'strategy': os.environ.get('GENETRADER_STRATEGY', 'GeneTrader'),
        'api_key': os.environ.get('GENETRADER_API_KEY', ''),
        'api_url': os.environ.get('GENETRADER_API_URL', 'http://localhost:8090'),
    }


def run_command(args):
    """Run a GeneTrader command and return output."""
    config = get_config()
    script = os.path.join(config['genetrader_path'], 'run_adaptive.py')

    if not os.path.exists(script):
        return {'error': f"GeneTrader not found at {config['genetrader_path']}"}

    cmd = ['python3', script] + args

    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=120,
            cwd=config['genetrader_path']
        )

        if result.returncode == 0:
            try:
                return json.loads(result.stdout)
            except json.JSONDecodeError:
                return {'output': result.stdout}
        else:
            return {'error': result.stderr or result.stdout}

    except subprocess.TimeoutExpired:
        return {'error': 'Command timed out'}
    except Exception as e:
        return {'error': str(e)}


def api_request(endpoint, method='GET', data=None):
    """Make an API request to the Agent API."""
    config = get_config()
    url = f"{config['api_url']}{endpoint}"

    headers = {
        'X-API-Key': config['api_key'],
        'Content-Type': 'application/json',
    }

    try:
        if data:
            body = json.dumps(data).encode()
        else:
            body = None

        req = Request(url, data=body, headers=headers, method=method)
        with urlopen(req, timeout=30) as response:
            return json.loads(response.read().decode())

    except URLError as e:
        return {'error': f'API not available: {e}'}
    except Exception as e:
        return {'error': str(e)}


def cmd_check(args):
    """Check strategy performance."""
    config = get_config()
    strategy = args[0] if args else config['strategy']

    result = run_command(['--strategy', strategy, '--check-only'])

    if 'error' in result:
        return format_error(result['error'])

    return format_check_result(result)


def cmd_status(args):
    """Get system status."""
    # Try API first
    result = api_request('/api/v1/status')

    if 'error' not in result:
        return format_status(result)

    # Fall back to command line
    config = get_config()
    result = run_command(['--strategy', config['strategy'], '--check-only'])

    if 'error' in result:
        return format_error(result['error'])

    return format_check_result(result)


def cmd_optimize(args):
    """Trigger optimization."""
    config = get_config()
    strategy = args[0] if args else config['strategy']

    result = run_command(['--strategy', strategy, '--force-optimize'])

    if 'error' in result:
        return format_error(result['error'])

    return f"""## Optimization Triggered

**Strategy**: {strategy}
**Status**: {'Success' if result.get('success') else 'Failed'}
**Message**: {result.get('message', 'No message')}
"""


def cmd_approvals(args):
    """List pending approvals."""
    result = api_request('/api/v1/approvals/pending')

    if 'error' in result:
        return format_error(result['error'])

    approvals = result.get('data', [])

    if not approvals:
        return "## No Pending Approvals\n\nAll deployments are up to date."

    output = "## Pending Approvals\n\n"
    for a in approvals:
        output += f"""### {a['request_id']}
- **Strategy**: {a['strategy_name']}
- **Version**: {a['version_id']}
- **Created**: {a['created_at']}
- **Metrics**: {json.dumps(a.get('metrics', {}), indent=2)}

"""
    return output


def cmd_approve(args):
    """Approve a deployment."""
    if not args:
        return format_error("Usage: genetrader approve <request_id>")

    request_id = args[0]
    result = api_request('/api/v1/deployment/approve', 'POST', {'request_id': request_id})

    if 'error' in result:
        return format_error(result['error'])

    return f"## Deployment Approved\n\n**Request ID**: {request_id}\n**Status**: Approved"


def cmd_reject(args):
    """Reject a deployment."""
    if not args:
        return format_error("Usage: genetrader reject <request_id> [reason]")

    request_id = args[0]
    reason = ' '.join(args[1:]) if len(args) > 1 else 'Rejected by operator'

    result = api_request('/api/v1/deployment/reject', 'POST', {
        'request_id': request_id,
        'reason': reason
    })

    if 'error' in result:
        return format_error(result['error'])

    return f"## Deployment Rejected\n\n**Request ID**: {request_id}\n**Reason**: {reason}"


def cmd_rollback(args):
    """Rollback to a previous version."""
    if not args:
        return format_error("Usage: genetrader rollback <strategy_name> [version_id]")

    strategy = args[0]
    version = args[1] if len(args) > 1 else None

    data = {'strategy_name': strategy}
    if version:
        data['to_version'] = version

    result = api_request('/api/v1/rollback', 'POST', data)

    if 'error' in result:
        return format_error(result['error'])

    return f"## Rollback Initiated\n\n**Strategy**: {strategy}\n**Target Version**: {version or 'Previous'}"


def format_check_result(result):
    """Format check result as markdown."""
    status = result.get('status', 'unknown')
    status_emoji = '✅' if status == 'healthy' else '⚠️' if status == 'degraded' else '❓'

    metrics = result.get('current_metrics', {})
    alerts = result.get('alerts', [])

    output = f"""## Strategy Performance Check {status_emoji}

**Status**: {status.upper()}
**Degradation Score**: {result.get('degradation_score', 0):.2f}
**Market Regime**: {result.get('market_regime', 'unknown')}

### Current Metrics
| Metric | Value |
|--------|-------|
| Profit % | {metrics.get('profit_pct', 0):.2%} |
| Win Rate | {metrics.get('win_rate', 0):.2%} |
| Max Drawdown | {metrics.get('max_drawdown', 0):.2%} |
| Total Trades | {metrics.get('total_trades', 0)} |

"""

    if alerts:
        output += "### Alerts\n"
        for alert in alerts:
            severity = alert.get('severity', 'info')
            emoji = '🔴' if severity == 'critical' else '🟡' if severity == 'warning' else '🔵'
            output += f"- {emoji} **{alert.get('alert_type', 'unknown')}**: {alert.get('message', '')}\n"
        output += "\n"

    output += f"### Recommendation\n{result.get('recommendation', 'No recommendation')}"

    return output


def format_status(result):
    """Format status as markdown."""
    data = result.get('data', {})
    opt_status = data.get('optimization', {})
    scheduler = data.get('scheduler', {})

    return f"""## System Status

### Optimization
- **State**: {opt_status.get('state', 'unknown')}
- **Strategy**: {opt_status.get('strategy_name', 'N/A')}
- **Can Optimize**: {opt_status.get('can_optimize', False)}
- **Last Optimization**: {opt_status.get('last_optimization', 'Never')}

### Scheduler
- **Queue Size**: {scheduler.get('queue_size', 0)}
- **Running**: {scheduler.get('running', 0)}
- **Completed Today**: {scheduler.get('completed_today', 0)}
- **Completed This Week**: {scheduler.get('completed_this_week', 0)}
"""


def format_error(error):
    """Format error message."""
    return f"## Error\n\n```\n{error}\n```"


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    command = sys.argv[1].lower()
    args = sys.argv[2:]

    commands = {
        'check': cmd_check,
        'status': cmd_status,
        'optimize': cmd_optimize,
        'approvals': cmd_approvals,
        'approve': cmd_approve,
        'reject': cmd_reject,
        'rollback': cmd_rollback,
    }

    if command in commands:
        result = commands[command](args)
        print(result)
    else:
        print(f"Unknown command: {command}")
        print(__doc__)
        sys.exit(1)


if __name__ == '__main__':
    main()
